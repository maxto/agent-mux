#!/usr/bin/env bash
# Mock tmux for install tests (not used in tmux-agent functional tests)
if [[ -n "${TMUX_FIXTURE_LOG:-}" ]]; then
  printf '%s\n' "$*" >> "$TMUX_FIXTURE_LOG"
fi

if [[ "${1:-}" == "-S" ]]; then
  shift 2
fi

case "$1" in
  -V)            echo "tmux 3.3a" ;;
  list-sessions) exit 0 ;;
  has-session)   exit "${TMUX_FIXTURE_HAS_SESSION:-1}" ;;
  new-session)
    case "$*" in
      *"-PF #{pane_id}"*) echo "${TMUX_FIXTURE_PANE_ID:-%1}" ;;
    esac
    ;;
  display-message)
    case "$*" in
      *'#{pane_id}'*) echo "${TMUX_FIXTURE_PANE_ID:-%1}" ;;
      *'#{window_id}'*) echo "${TMUX_FIXTURE_WINDOW_ID:-@1}" ;;
      *'#{session_name}:#{window_index}.#{pane_index}'*) echo "agents:0.0" ;;
    esac
    ;;
  split-window)
    case "$*" in
      *' -h '*) echo "${TMUX_FIXTURE_SPLIT_H:-%2}" ;;
      *)        echo "${TMUX_FIXTURE_SPLIT_V:-%3}" ;;
    esac
    ;;
  list-panes)
    if [[ -n "${TMUX_FIXTURE_LIST_PANES:-}" ]]; then
      printf '%s\n' "$TMUX_FIXTURE_LIST_PANES"
    fi
    ;;
  source-file)   exit 0 ;;
  *)             exit 0 ;;
esac
